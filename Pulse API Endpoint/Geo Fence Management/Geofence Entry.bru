script:pre-request {
  try {
      const response = await bru.sendRequest({
          url: "https://pm-echo.com/get",
          method: "GET"
      });
  
      console.log(response.json());
  } catch (err) {
      console.error(err);
  }
  try {
      const response = await bru.sendRequest({
          url: "https://pm-echo.com/get",
          method: "GET"
      });
  
      console.log(response.json());
  } catch (err) {
      console.error(err);
  }
}

script:post-response {
  var template = `
  <canvas id="myChart" height="75"></canvas>
  
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js"></script> 
  
  <script>
      var ctx = document.getElementById("myChart");
  
      var myChart = new Chart(ctx, {
          type: "bar",
          data: {
              labels: ["Status Code", "Status Message"],
              datasets: [{
                  data: [{{response.statusCode}}, "{{response.statusMessage}}"],
                  
                  // Change these colours to customize the chart
                  backgroundColor: ["#003f5c", "#58508d", "#bc5090", "#ff6361", "#ffa600"],
              }]
          },
          options: {
              legend: { display: false },
              title: {
                  display: true,
                  text: 'Response Data'
              },
              scales: {
                  xAxes: [{
                      display: true,
                      scaleLabel: {
                          display: true,
                          labelString: 'Data'
                      }
                  }],
                  yAxes: [{
                      display: true,
                      scaleLabel: {
                          display: true,
                          labelString: 'Value'
                      }
                  }]
              }
          }
  
      });
  
  //     // Access the data passed to pm.visualizer.set() from the JavaScript
      // code of the Visualizer template
  //     pm.getData(function (err, value) {
          myChart.data.datasets[0].data = [value.response.statusCode, value.response.statusMessage];
          myChart.update();
      });
  
  </script>`;
  
  function constructVisualizerPayload() {
      var res = res.getBody();
      
      var visualizerData = {
          
          // Status Code as a number
          statusCode: res.statusCode,
          
          // Status Message as a string
          statusMessage: res.statusMessage
      };
  
      return {response: visualizerData};
  }
  
  // pm.visualizer.set(template, constructVisualizerPayload());
}

settings {
  encodeUrl: true
}

example {
  name: Geofence Entry
  
  request: {
    url: {{pulse_api}}/GeoFence/GeofenceEntry
    method: POST
    mode: json
    body:json: {
      {
          "Id": "", // new entry-> Id empty, exiting entry have Id
          "SubMarketId": "0DA92D48-1902-4E9D-8642-00000275E02D",
          "Lat": "23.00",
          "Lon": "34.93",
          "CreatedBy": "C2580795-73E9-41A4-A05C-9697232D1A67",
          "ModifiedBy": "C2580795-73E9-41A4-A05C-9697232D1A67"
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json; charset=utf-8
      Date: Mon, 10 Feb 2025 05:39:54 GMT
      Server: Kestrel
      Transfer-Encoding: chunked
    }
  
    status: {
      code: OK
      text: 200
    }
  
    body: {
      type: json
      content: '''
        {
            "statusCode": 200,
            "statusMessage": "Geofence entry processed successfully"
        }
      '''
    }
  }
}

