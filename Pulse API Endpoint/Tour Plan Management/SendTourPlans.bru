example {
  name: SendTourPlans_Example
  
  request: {
    url: {{pulse_api}}/TourPlan/SendTourPlan
    method: POST
    mode: json
    body:json: {
      [
          {
              "ID": "", // ID empty means new entry
              "planEntryBy": "17801",
              "planEntryDate": "2024-07-14",
              "planModificationDateTime": "", // emptry for first time entry
              "planYear": "2024",
              "planMonth": "7",
              "planDay": "14",
              "planLocation": "Head-Quarter",
              "planSession": "Morning",
              "planNote": "Note",
              "planEntryLocation": "",
              "planStatus": 0, // 0 for new entry, 2 for edit request
              "subMarketList": [
                  {
                      "subMarketId": "id1",
                      "headType": "Own",
                      "geoFenceId": "id1"
                  },
                  {
                      "subMarketId": "id2",
                      "headType": "Own",
                      "geoFenceId": "id1"
                  },
                  {
                      "subMarketId": "id3",
                      "headType": "Pair",
                      "geoFenceId": "id1"
                  }
              ]
          }
      ]
    }
  }
  
